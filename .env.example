# Nhost (Faz 2'de kullanılacak — Postgres + Hasura GraphQL + Auth + Storage)
NEXT_PUBLIC_NHOST_SUBDOMAIN=
NEXT_PUBLIC_NHOST_REGION=

# WhatsApp Cloud API (Faz 5 — Faz B, tam entegrasyon)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# Site
NEXT_PUBLIC_SITE_URL=https://lumiaclub.com

# Google Analytics 4 — panelde gerçek veri için
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Admin panel — oturum tabanlı giriş (cookie). Ayarlanmazsa /admin erişilemez kalır.
ADMIN_USER=
ADMIN_PASSWORD=
# Opsiyonel: oturum imzası için ayrı secret (yoksa ADMIN_PASSWORD kullanılır)
ADMIN_SESSION_SECRET=

# SMTP (Hostinger) — iletişim formu ve randevu bildirimleri için.
# EMAIL_PASSWORD boşsa e-posta gönderimi sessizce atlanır, site çökmez.
# IMAP (imap.hostinger.com) sadece işletmenin kendi mail istemcisi içindir, kodda kullanılmaz.
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=465
EMAIL_USER=info@lumiaclub.com
EMAIL_PASSWORD=
EMAIL_FROM="Lumia <info@lumiaclub.com>"
